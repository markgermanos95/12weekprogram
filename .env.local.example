# Copy this file to .env.local and fill in real values.
#
# These three come from a Google Cloud "service account" — see README.md
# for the exact click-path to create one. Once created, share your Google
# Sheet with the service account's email (as Editor) — same idea as sharing
# a sheet with any other Google user.

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-bot@your-project.iam.gserviceaccount.com

# Paste the private_key value from the downloaded JSON key file exactly as-is,
# including the literal \n characters — keep it wrapped in double quotes.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# The long ID from your Google Sheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your-sheet-id-here

